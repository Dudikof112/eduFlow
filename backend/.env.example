# Backend .env.example — ustaw zmienne na serwerze Render
# Bazy danych będą hostowane np. na ElephantSQL (PostgreSQL) i MongoDB Atlas

# PostgreSQL (np. ElephantSQL na Render)
DB_HOST=your-elephant-sql-host
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database

# MongoDB Atlas (darmowy tier na mongodb.com)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/elearning?retryWrites=true&w=majority

# JWT Secret — losowy string (wygeneruj sam, minimum 20 znaków)
JWT_SECRET=your_super_secret_jwt_key_minimum_20_characters_long

# Port (Render ustawi PORT automatycznie, ale bezpieczeństwo wymaga wartości domyślnej)
PORT=5000

# Stripe (testowy klucz — patrz dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL (gdzie będzie hostowany frontend na Render)
CLIENT_URL=https://your-frontend-url.onrender.com
